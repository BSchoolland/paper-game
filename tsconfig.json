{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true
  },
  // web/ is Svelte: raw tsc doesn't know runes — it's checked by `svelte-check` (web/package.json "check").
  "exclude": ["web", "node_modules"]
}
